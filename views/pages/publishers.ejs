<!doctype html>
<html lang="en">
<head>
  <%- include('../partials/head', { pageTitle }) %>
</head>
<body>
  <%- include('../partials/navbar', { activePage }) %>

  <main class="content">
    <section class="welcome-section">
      <h1 class="page-title">Authors & Publishers</h1>
      <p class="lede page-copy">Browse the names behind the catalog and jump back into the matching books.</p>
    </section>

    <section class="info-grid">
      <% (publishers || []).forEach((publisher) => { %>
        <article class="info-card">
          <h3><%= publisher %></h3>
          <p><%= (books || []).filter((book) => (book.Publisher || 'Unknown') === publisher).length %> book(s) published here.</p>
          <a class="secondary-button" href="/books?q=<%= encodeURIComponent(publisher) %>">View books</a>
        </article>
      <% }) %>
    </section>
  </main>

  <%- include('../partials/footer') %>
  <script src="/js/main.js"></script>
</body>
</html>